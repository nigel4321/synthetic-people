manifest {
    name            = 'variant-scan'
    description     = 'Scan multiple VCF files for a target variant across a population'
    version         = '0.1.0'
    mainScript      = 'main.nf'
    nextflowVersion = '>=22.10.0'
}

params {
    input           = null
    outdir          = 'results'

    variant_name    = null
    variant_chrom   = null
    variant_pos     = null
    variant_ref     = null
    variant_alt     = null
    variant_min_af  = 0.0
    variant_max_af  = 1.0

    // Set false to turn QC warnings/failures into report-only (pipeline
    // continues even when a file fails hard checks). Default true aborts
    // on any hard failure (unreadable file, missing index, no samples, etc.).
    strict_qc          = true

    // PCA_PLOT thresholds. The defaults match plot_pca.py's defaults; the
    // pipeline surfaces them so users with deliberately small or very
    // large cohorts can override from the CLI without editing the script.
    //   - pca_min_samples   : skip PCA when fewer (no meaningful 2-PC fit)
    //   - pca_min_variants  : skip PCA when fewer variable sites remain
    //                         after zero-variance pruning
    //   - pca_max_variants  : cap on the number of variants fed into PCA
    //                         (random prefix in file order). Larger values
    //                         are slower and rarely change the result for
    //                         typical cohort sizes.
    pca_min_samples    = 3
    pca_min_variants   = 10
    pca_max_variants   = 10000
}

process {
    executor = 'local'
    cpus     = 1
    memory   = '1.GB'

    withName: 'QC_VALIDATE|INSPECT_VCF|SCAN_VARIANT|BCFTOOLS_STATS' {
        cpus   = 1
        memory = '1.GB'
    }
    withName: 'PCA_PLOT' {
        // PCA loads the full samples × variants dosage matrix into RAM.
        // For a 2 504-sample chr22 1000G VCF that's ~50 MB at most;
        // 2 GB leaves comfortable headroom for sklearn's intermediate
        // SVD allocations.
        cpus   = 1
        memory = '2.GB'
    }
    withName: 'QC_REPORT|METADATA_REPORT|VARIANT_REPORT|CARRIER_REPORT' {
        cpus   = 1
        memory = '512.MB'
    }
    withName: 'MULTIQC' {
        cpus   = 1
        memory = '2.GB'
    }
}

executor {
    name      = 'local'
    queueSize = 16
}

profiles {
    standard {
        // Defaults above — suitable for a mid-size VM.
    }
    small_vm {
        executor.queueSize = 4
    }
    big_vm {
        executor.queueSize = 32
    }
}
