manifest {
    name            = 'variant-scan'
    description     = 'Scan multiple VCF files for a target variant across a population'
    version         = '0.1.0'
    mainScript      = 'main.nf'
    nextflowVersion = '>=22.10.0'
}

params {
    input           = null
    outdir          = 'results'

    variant_name    = null
    variant_chrom   = null
    variant_pos     = null
    variant_ref     = null
    variant_alt     = null
    variant_min_af  = 0.0
    variant_max_af  = 1.0

    // Set false to turn QC warnings/failures into report-only (pipeline
    // continues even when a file fails hard checks). Default true aborts
    // on any hard failure (unreadable file, missing index, no samples, etc.).
    strict_qc       = true
}

process {
    executor = 'local'
    cpus     = 1
    memory   = '1.GB'

    withName: 'QC_VALIDATE|INSPECT_VCF|SCAN_VARIANT|BCFTOOLS_STATS' {
        cpus   = 1
        memory = '1.GB'
    }
    withName: 'QC_REPORT|METADATA_REPORT|VARIANT_REPORT|CARRIER_REPORT' {
        cpus   = 1
        memory = '512.MB'
    }
    withName: 'MULTIQC' {
        cpus   = 1
        memory = '2.GB'
    }
}

executor {
    name      = 'local'
    queueSize = 16
}

profiles {
    standard {
        // Defaults above — suitable for a mid-size VM.
    }
    small_vm {
        executor.queueSize = 4
    }
    big_vm {
        executor.queueSize = 32
    }
}
